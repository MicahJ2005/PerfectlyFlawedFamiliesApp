rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users — only the owner can read/write their own profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Saved devotions & family sessions (sub-collections)
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Public prayer requests — authenticated users can read all, write their own
    match /prayerRequests/{prayerId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        // owner can deactivate their own prayer
        resource.data.uid == request.auth.uid ||
        // anyone can increment hearts / add to prayedBy
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hearts', 'prayedBy'])
      );
      allow delete: if false;
    }

    // Private prayer groups
    match /privateGroups/{groupId} {
      // Members can read their own group; any auth user can list/query (needed to join by code)
      allow get:    if request.auth != null && request.auth.uid in resource.data.members;
      allow list:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        // members can join/leave or update memberNames
        request.auth.uid in resource.data.members ||
        request.auth.uid in request.resource.data.members
      );
      allow delete: if false;

      match /prayers/{prayerId} {
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/privateGroups/$(groupId)).data.members;
        allow create: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/privateGroups/$(groupId)).data.members;
        allow update: if request.auth != null && (
          resource.data.uid == request.auth.uid ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hearts', 'prayedBy'])
        );
        allow delete: if false;
      }
    }

    // Push subscriptions — owner only
    match /pushSubscriptions/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Access codes — read for redemption (Cloud Function handles the write)
    match /accessCodes/{code} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Verses — any authenticated user can read
    match /verses/{verseId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
